# KAboutData short description
#: szafir-host-proxy/main.cpp:159
msgid "Szafir native messaging proxy and host integrator."
msgstr "Proxy komunikacji natywnej i integrator hosta aplikacji Szafir."

# CLI option: --install
#: szafir-host-proxy/main.cpp:184
msgid "Install native host definitions and wrappers, then exit."
msgstr "Zainstaluj definicje oraz skrypty pośredniczące natywnego hosta i zakończ działanie."
"Zainstaluj definicje oraz skrypty pośredniczące natywnego hosta i zakończ "
"działanie."

# CLI option: --uninstall
#: szafir-host-proxy/main.cpp:187
msgid "Remove native host definitions/wrappers and permissions, then exit."
msgstr "Usuń definicje/skrypty pośredniczące natywnego hosta oraz uprawnienia i zakończ działanie."
"Usuń definicje/skrypty pośredniczące natywnego hosta oraz uprawnienia i "
"zakończ działanie."

# CLI option: --dry-run
#: szafir-host-proxy/main.cpp:190
msgid ""
"Print planned file/permission operations without performing them. Requires --"
"install or --uninstall."
msgstr ""
"Wyświetl planowane operacje na plikach/uprawnieniach bez ich wykonywania. "
"Wymaga podania opcji --install lub --uninstall."

#: szafir-host-proxy/main.cpp:193
msgid "Show modeless status window when launched."
msgstr "Pokaż niemodalne okno statusu podczas uruchamiania."

#: szafir-host-proxy/main.cpp:196
msgid "Show the first-run setup wizard even if all checks already pass."
msgstr "Pokaż kreator konfiguracji nawet jeśli wszystkie testy zostały spełnione."

# CLI error: conflicting options
#: szafir-host-proxy/main.cpp:214
msgid "Use either --install or --uninstall, not both."
msgstr "Użyj opcji --install albo --uninstall, nie obu jednocześnie."

# CLI error: dry-run without action
#: szafir-host-proxy/main.cpp:219
msgid "--dry-run requires --install or --uninstall."
msgstr "Opcja --dry-run wymaga podania opcji --install lub --uninstall."

# CLI error: install failed
#: szafir-host-proxy/main.cpp:227
msgid "Failed to install native host integration."
msgstr "Nie udało się zainstalować integracji natywnego hosta."

# CLI info: dry-run install done
#: szafir-host-proxy/main.cpp:230
msgid "Dry-run install complete."
msgstr "Próbna instalacja zakończona."

# CLI info: install succeeded
#: szafir-host-proxy/main.cpp:230
msgid "Native host integration installed."
msgstr "Pomyślnie zainstalowano integrację natywnego hosta."

# CLI error: uninstall failed
#: szafir-host-proxy/main.cpp:236
msgid "Failed to uninstall native host integration."
msgstr "Nie udało się odinstalować integracji natywnego hosta."

# CLI info: dry-run uninstall done
#: szafir-host-proxy/main.cpp:239
msgid "Dry-run uninstall complete."
msgstr "Próbne odinstalowanie zakończone."

# CLI info: uninstall succeeded
#: szafir-host-proxy/main.cpp:239
msgid "Native host integration removed."
msgstr "Pomyślnie usunięto integrację natywnego hosta."

# CLI error: D-Bus session bus unavailable
#: szafir-host-proxy/main.cpp:245
msgid "Cannot connect to the D-Bus session bus."
msgstr "Nie można połączyć się z magistralą sesji D-Bus."

# CLI info: already running
#: szafir-host-proxy/main.cpp:251
msgid "szafir-host-proxy is already running."
msgstr "Program szafir-host-proxy jest już uruchomiony."

# CLI error: D-Bus object registration failed
#: szafir-host-proxy/main.cpp:257
msgid "Failed to register D-Bus object."
msgstr "Nie udało się zarejestrować obiektu D-Bus."

# Warning: auto-install on startup failed
#: szafir-host-proxy/main.cpp:262
msgid "Failed to fully install native host integration; continuing startup."
msgstr "Nie udało się w pełni zainstalować integracji natywnego hosta; uruchamianie będzie kontynuowane."
"Nie udało się w pełni zainstalować integracji natywnego hosta; uruchamianie "
"będzie kontynuowane."

