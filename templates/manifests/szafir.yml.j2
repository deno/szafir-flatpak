app-id: pl.kir.szafir
runtime: org.freedesktop.Platform
runtime-version: '25.08'
sdk: org.freedesktop.Sdk
command: szafir_start.sh

sdk-extensions:
  - org.freedesktop.Sdk.Extension.openjdk25

finish-args:
  - --socket=pcsc
  - --share=network
  - --socket=x11
  - --share=ipc
  - --filesystem=xdg-documents
  - --persist=.java
  - --persist=KIR
  - --env=PATH=/app/jre/bin:/app/bin:/usr/bin
  - --env=JAVA_HOME=/app/jre

cleanup:
  - /include
{% for comp in system_components %}
{% for path in comp.cleanup %}
  - {{ path }}
{% endfor %}
{% endfor %}
  - /lib/pkgconfig
  - /share/doc
  - /share/man
  - /sbin

modules:
{% include 'fragments/openjdk_module.yml.j2' %}
{% for comp in system_components %}

  - name: {{ comp.id }}
    buildsystem: {{ comp.build.buildsystem }}
    config-opts:
{% for opt in comp.build.config_opts %}
      - {{ opt }}
{% endfor %}
    post-install:
      - install -Dm644 ../COPYING /app/share/licenses/$FLATPAK_ID/{{ comp.id }}/COPYING
    sources:
      - type: archive
        url: {{ comp.source_url }}
        sha256: {{ comp.source_sha256 }}
{% endfor %}

  - name: szafir
    buildsystem: simple
    build-commands:
      - install -D -m 755 szafir_apply_extra.sh /app/bin/apply_extra
      - install -D -m 755 szafir_start.sh /app/bin/szafir_start.sh
      - install -D -m 644 pl.kir.szafir.metainfo.xml /app/share/metainfo/pl.kir.szafir.metainfo.xml
      - install -D -m 644 pl.kir.szafir.desktop /app/share/applications/pl.kir.szafir.desktop
      - install -D -m 644 szafir_icon.svg /app/share/icons/hicolor/scalable/apps/pl.kir.szafir.svg
    sources:
      - type: file
        path: szafir_start.sh
      - type: file
        path: szafir_apply_extra.sh
      - type: file
        path: pl.kir.szafir.desktop
      - type: file
        path: pl.kir.szafir.metainfo.xml
      - type: file
        path: szafir_icon.svg
      - type: extra-data
        filename: szafir_Linux.zip
        url: https://storage.googleapis.com/cdn.elektronicznypodpis.pl/Szafir/szafir_Linux.zip?generation=1770199099953025
        sha256: 50a3f4a25a427e1ea2e780d52796393ca6aa7e26faa5f477bbff67942b2c5cd5
        size: 48801916
