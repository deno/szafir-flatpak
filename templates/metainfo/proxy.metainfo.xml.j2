<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>{{ app_id }}</id>
  <name>SzafirHostProxy</name>
  <summary>{{ summary_en }}</summary>
  <summary xml:lang="pl">{{ summary_pl }}</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-2.0-only</project_license>
  <developer id="pl.deno">
    <name>deno</name>
  </developer>
  <releases>
{% for release in releases %}
    <release version="{{ release.version }}" date="{{ release.date }}">
      <description>
        <p>{{ release.description.en }}</p>
{% if release.description.pl is defined %}
        <p xml:lang="pl">{{ release.description.pl }}</p>
{% endif %}
      </description>
    </release>
{% endfor %}
  </releases>
  <description>
    <p>
      SzafirHostProxy is an open-source Native Messaging bridge for Szafir on Linux. It connects
      supported browsers with the Szafir signing environment so qualified signatures can work on
      supported websites.
    </p>
    <p>
      The GitHub repository publishes a proxy build that keeps copyrighted runtime components out of
      the Flatpak image. The bridge downloads required upstream runtime components during first-run
      setup instead of bundling them inside the image.
    </p>
    <p>Supported browsers include:</p>
    <ul>
      <li>Mozilla Firefox, LibreWolf, Waterfox</li>
      <li>Google Chrome, Google Chrome Dev</li>
      <li>Chromium, Ungoogled Chromium</li>
    </ul>
    <p>Features:</p>
    <ul>
      <li>Guides first-run setup with a welcome screen, component download step, and license screen.</li>
      <li>Installs browser integration files for supported host and Flatpak browsers.</li>
      <li>Shows a live status window that waits for browser activity and links to browser extensions.</li>
      <li>Lets you remove installed browser integrations at any time.</li>
    </ul>
    <p>
      Browser integrations can be removed manually at any time by running: flatpak run {{ app_id }} --uninstall
    </p>
    <p xml:lang="pl">
      SzafirHostProxy to otwartoźródłowy most Native Messaging dla środowiska Szafir na Linuksie.
      Łączy wspierane przeglądarki z aplikacjami Szafir, aby kwalifikowany podpis elektroniczny
      działał na wspieranych stronach internetowych.
    </p>
    <p xml:lang="pl">
      Repozytorium GitHub publikuje wydanie proxy, które nie zawiera komponentów objętych prawami
      autorskimi wewnątrz obrazu Flatpak. Sam most komunikacyjny może pobrać wymagane komponenty
      środowiska producenta podczas pierwszej konfiguracji zamiast dołączać je do obrazu aplikacji.
    </p>
    <p xml:lang="pl">Wspierane przeglądarki:</p>
    <ul>
      <li xml:lang="pl">Mozilla Firefox, LibreWolf, Waterfox</li>
      <li xml:lang="pl">Google Chrome, Google Chrome Dev</li>
      <li xml:lang="pl">Chromium, Ungoogled Chromium</li>
    </ul>
    <p xml:lang="pl">Funkcje:</p>
    <ul>
      <li xml:lang="pl">Prowadzi użytkownika przez pierwszą konfigurację z ekranem powitalnym, pobieraniem komponentów i akceptacją licencji.</li>
      <li xml:lang="pl">Instaluje integrację przeglądarkową dla wspieranych przeglądarek systemowych i Flatpak.</li>
      <li xml:lang="pl">Wyświetla ekran statusu oczekujący na aktywność przeglądarki oraz odsyłacze do rozszerzeń.</li>
      <li xml:lang="pl">Pozwala w dowolnym momencie usunąć zainstalowaną integrację przeglądarkową.</li>
    </ul>
    <p xml:lang="pl">
      Integracje mogą zostać ręcznie odinstalowane w dowolnym momencie poprzez uruchomienie polecenia: flatpak run {{ app_id }} --uninstall
    </p>
  </description>
  <url type="homepage">https://github.com/deno/szafir-flatpak</url>
  <url type="bugtracker">https://github.com/deno/szafir-flatpak/issues</url>
  <launchable type="desktop-id">{{ app_id }}.desktop</launchable>
  <content_rating type="oars-1.1" />
  <requires>
    <control>keyboard</control>
    <control>pointing</control>
    <display_length compare="ge">768</display_length>
  </requires>
{% include 'fragments/proxy_screenshots.xml.j2' %}
</component>
